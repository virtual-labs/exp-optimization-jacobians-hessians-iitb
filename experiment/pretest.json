{"version": 2.0, "questions": [{"question": "What does the Jacobian matrix represent?", "answers": {"a": "Second order partial derivatives of a function", "b": "First order partial derivatives of vector functions", "c": "Determinant of a matrix", "d": "Gradient of a scalar function"}, "explanations": {"a": "", "b": "", "c": "", "d": ""}, "correctAnswer": "b", "difficulty": "beginner"}, {"question": "If <span style='display:inline-block;'> $$F(x,y) = (x^2 + y,\\; xy)$$ </span>, what is the Jacobian matrix?", "answers": {"a": "$$\\begin{bmatrix}2x & 1 \\\\ y & x\\end{bmatrix}$$", "b": "$$\\begin{bmatrix}x & y \\\\ 2x & 1\\end{bmatrix}$$", "c": "$$\\begin{bmatrix}2 & 1 \\\\ y & x\\end{bmatrix}$$", "d": "$$\\begin{bmatrix}2x & y \\\\ 1 & x\\end{bmatrix}$$"}, "explanations": {"a": "", "b": "", "c": "", "d": ""}, "correctAnswer": "a", "difficulty": "beginner"}, {"question": "The Jacobian matrix of a function $$F: \\mathbb{R}^n \\rightarrow \\mathbb{R}^m$$ has dimensions:", "answers": {"a": "$$n \\times m$$", "b": "$$m \\times n$$", "c": "$$n \\times n$$", "d": "$$m \\times m$$"}, "explanations": {"a": "", "b": "", "c": "", "d": ""}, "correctAnswer": "b", "difficulty": "beginner"}, {"question": "The Hessian matrix contains:", "answers": {"a": "First order derivatives", "b": "Second order partial derivatives", "c": "Determinants of derivatives", "d": "Integrals of functions"}, "explanations": {"a": "", "b": "", "c": "", "d": ""}, "correctAnswer": "b", "difficulty": "beginner"}, {"question": "What is the Hessian matrix of $$f(x,y) = x^2 + y^2$$?", "answers": {"a": "$$\\begin{bmatrix}2 & 0 \\\\ 0 & 2\\end{bmatrix}$$", "b": "$$\\begin{bmatrix}x & y \\\\ y & x\\end{bmatrix}$$", "c": "$$\\begin{bmatrix}2x & 0 \\\\ 0 & 2y\\end{bmatrix}$$", "d": "$$\\begin{bmatrix}1 & 1 \\\\ 1 & 1\\end{bmatrix}$$"}, "explanations": {"a": "", "b": "", "c": "", "d": ""}, "correctAnswer": "a", "difficulty": "beginner"}]}